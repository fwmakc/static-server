# Server
NODE_ENV = dev
PORT = 8080

# i18n — default language
LANG = en
# i18n — available languages (JSON array)
LANGS = ["ru", "en"]

# i18n — default namespace
LANG_FILE = default
# i18n — loaded namespaces (JSON array)
LANG_FILES = ["agency", "common", "counter", "country", "currency", "datetime", "default", "nav", "social"]

# Template directory (relative to project root)
TEMPLATE = view/default
