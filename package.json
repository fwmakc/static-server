{
  "name": "scs",
  "version": "1.0.0",
  "description": "Static Content Server",
  "main": "dist/server.js",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint --ext .ts ./",
    "format": "prettier --write \"**/*.{ts,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 1"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "http-errors": "^2.0.0",
    "i18next": "^22.4.10",
    "i18next-fs-backend": "^2.1.1",
    "i18next-http-middleware": "^3.2.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/http-errors": "^2.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "morgan": "^1.10.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
