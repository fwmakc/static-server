{
  "name": "scs",
  "version": "1.0.0",
  "description": "Static Content Server",
  "main": "dist/server.js",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint --ext .ts ./",
    "format": "prettier --write \"**/*.{ts,scss,html,md,json}\" --ignore-path .gitignore",
    "scss": "sass static/scss/main.scss static/css/main.css --style=compressed",
    "scss:watch": "sass static/scss/main.scss static/css/main.css --style=compressed --watch",
    "test": "npm run scss && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.22.2",
    "http-errors": "^2.0.1",
    "i18next": "^24.2.3",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-middleware": "^3.9.7",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/http-errors": "^2.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
